{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(config/credentials/**)",
      "Edit(terraform/prod/**)",
      "Edit(k8s/prod/**)",
      "Bash(terraform destroy*)",
      "Bash(kubectl delete*)",
      "Bash(rm -rf /*)",
      "Bash(git push --force*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(terraform apply*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl rollout*)",
      "Bash(psql*)",
      "Bash(docker push*)"
    ],
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(cat*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(npm test*)",
      "Bash(pnpm test*)",
      "Bash(yarn test*)",
      "Bash(pytest*)",
      "Bash(cargo test*)",
      "Bash(npm run lint*)",
      "Bash(pnpm lint*)",
      "Bash(yarn lint*)",
      "Bash(ruff*)",
      "Bash(cargo fmt*)",
      "Bash(cargo clippy*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-risky-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-after-edit.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/task-summary.sh"
          }
        ]
      }
    ]
  }
}